{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // renderer는 Canvas 2D API를 직접 다루므로 DOM 타입이 필수다
    // (루트 base의 lib=["ES2022"]에는 HTMLCanvasElement·OffscreenCanvas·CanvasRenderingContext2D가 없다).
    // lib은 상속이 아닌 대체이므로 ES2022를 함께 명시한다. 패키지 경계 내 override.
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src"]
}
