{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@tetorial/web": ["./apps/web/src/index.ts"],
      "@tetorial/gist-proxy": ["./workers/gist-proxy/src/index.ts"],
      "@tetorial/*": ["./packages/*/src/index.ts"]
    }
  }
}
